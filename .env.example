# Public host (nip.io); used by Caddy hostnames and Gitea URLs
SERVER_IP=1.2.3.4

# First MCP user (Postgres users.id=1) — must match Gitea admin username from setup
MCP_FIRST_USERNAME=user

# Caddy: restrict who can reach gitea / admin (TLS client IP). MCP endpoint is not IP-filtered (Bearer token in app).
# false = allow all. true = only CADDY_WHITELIST_IPS (space-separated CIDRs, e.g. 203.0.113.5/32 10.0.0.0/8)
CADDY_WHITELIST_ENABLED=false
CADDY_WHITELIST_IPS=

# Postgres
POSTGRES_PASSWORD=change_me
MCP_DB_PASSWORD=change_me
GITEA_DB_PASSWORD=change_me

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# Gitea
GITEA_SECRET_KEY=change_me_32chars_min
GITEA_INTERNAL_TOKEN=change_me_long_random
GITEA_DOMAIN=gitea.1.2.3.4.nip.io
GITEA_ROOT_URL=https://gitea.1.2.3.4.nip.io/

# MCP
GITEA_TOKEN=change_me
LLM_CHAT_URL=
LLM_CHAT_KEY=
LLM_CHAT_MODEL=gemini-2.5-flash
EMBEDDINGS_URL=https://generativelanguage.googleapis.com/v1beta
EMBEDDINGS_KEY=
EMBEDDINGS_MODEL=models/text-embedding-004
AUTO_SUMMARIZE=false
AUTO_SUMMARIZE_TRIGGER=20
# MCP local git clones: auto-remove after N days of inactivity (0 = off)
GIT_LOCAL_REPOS_TTL_DAYS=7
# Author/committer for git_commit in local clones (no ~/.gitconfig required)
GIT_COMMIT_USER_NAME=ai-agent
GIT_COMMIT_USER_EMAIL=ai@memory.local
